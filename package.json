{
    "name": "auth-service",
    "version": "1.0.0",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "dev": "cross-env NODE_ENV=dev nodemon --exec tsx src/server.ts",
        "format:fix": "prettier . --write",
        "format:check": "prettier . --check",
        "lint:check": "eslint . ",
        "lint:fix": "eslint . --fix",
        "test": "vitest --no-cache",
        "file:test" : "vitest",
        "prepare": "husky",
        "build" : "tsc",
        "migration:generate": "typeorm-ts-node-esm migration:generate -d src/config/data-source.ts",
        "migration:run": "typeorm-ts-node-esm migration:run -d src/config/data-source.ts",
        "migration:create": "typeorm-ts-node-esm migration:create",
        "migration:revert": "typeorm-ts-node-esm migration:revert -d src/config/data-source.ts",
        "migration:show": "typeorm-ts-node-esm migration:show -d src/config/data-source.ts",
        "schema:drop": "typeorm-ts-node-esm schema:drop -d src/config/data-source.ts"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "The user management service",
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@swc/jest": "^0.2.39",
        "@types/bcrypt": "^6.0.0",
        "@types/express": "^5.0.6",
        "@types/node": "^25.2.1",
        "@types/supertest": "^6.0.3",
        "eslint": "^9.39.2",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "mock-jwks": "^3.1.0",
        "nodemon": "^3.1.11",
        "prettier": "3.8.1",
        "supertest": "^7.2.2",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.54.0",
        "vitest": "^3.2.4"
    },
    "lint-staged": {
        "*.ts": [
            "prettier --write",
            "eslint --fix"
        
        ]
    },
    "dependencies": {
        "@types/cookie-parser": "^1.4.10",
        "@types/jsonwebtoken": "^9.0.10",
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cross-env": "^10.1.0",
        "dotenv": "^17.2.4",
        "express": "^5.2.1",
        "express-jwt": "^8.5.1",
        "http-errors": "^2.0.1",
        "jose": "^6.1.3",
        "jsonwebtoken": "^9.0.3",
        "jwks-rsa": "^3.2.2",
        "pg": "^8.18.0",
        "reflect-metadata": "^0.2.2",
        "typeorm": "^0.3.28",
        "winston": "^3.19.0",
        "zod": "^4.3.6"
    }
}
